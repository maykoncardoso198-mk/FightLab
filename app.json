{
  "expo": {
    "name": "FightLab",
    "slug": "fightlab",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fightlab",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "cover",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fightlab.app"
    },
    "android": {
      "package": "com.fightlab.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
